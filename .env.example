# Anthropic API Configuration
ANTHROPIC_API_KEY=your_api_key_here

# Model Selection (optional, default: claude-haiku-4-5-20251001)
# Options: claude-haiku-4-5-20251001, claude-sonnet-4-6, claude-opus-4-6
MODEL_ID=claude-haiku-4-5-20251001

# File Size Limits (optional)
# Maximum size per file in bytes (default: 10MB = 10485760)
MAX_FILE_SIZE=10485760

# Maximum total input size in bytes (default: 100MB = 104857600)
MAX_TOTAL_SIZE=104857600

# Logging Level (optional, default: info)
# Options: debug, info, warn, error
LOG_LEVEL=info

# JWT Authentication (required for API access)
# Generate a secure secret: openssl rand -hex 32
# Must be at least 32 characters for production
JWT_SECRET=your_jwt_secret_here_at_least_32_chars
